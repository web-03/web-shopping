<body>
	<% include ./../elements/header %>
	<h3 style="margin: 15px;margin-left:201px">Thông tin tài khoản</h3>

	<div class="row" style="width:1000px;margin:auto">
			<div class="col-lg-6">
				<div class="main_input_info_account">
					<div class="col-lg-12">
						<div class="form-group relative block_icon_form">
								<input type="text" class="form-control"  value="<%=customer.name%>"disabled="disabled">
						</div>
					</div>
					<div class="col-lg-12">
							<div class="form-group relative block_icon_form">
									<input type="text" class="form-control"  value="<%=customer.account%>"disabled="disabled">
							</div>
					</div>
					<div class="col-lg-12">
							<div class="form-group relative block_icon_form">
									<input type="text" class="form-control" value="<%=customer.phoneNumber%>"disabled="disabled">
							</div>
					</div>
					<div class="col-lg-12">
							<div class="form-group relative block_icon_form">
									<input type="text" class="form-control"  value="<%=customer.place%>"disabled="disabled">
							</div>
					</div>
					<div class="col-lg-12" style="margin-left: 170px">
							<div class="form-group relative block_icon_form">
									<button class="btn" id="myBtn">Cập nhật</button>
							</div>
					</div>
				</div>
			</div>
	</div>
	<div id="update" class="user_info" style="margin-top:50px">

		<!-- user_info content -->
		<form action="" method="POST">
		<div class="user_info-content" style="width:400px">
		  <span class="close">&times;</span>
		  <input type="text" class="form-control" name="name" style="margin-bottom:5px" value="<%=customer.name%>">
		  <input type="text" class="form-control" name="phone" style="margin-bottom:5px" value="<%=customer.phoneNumber%>">
		  <input type="text" class="form-control" name="address" style="margin-bottom:5px" value="<%=customer.place%>">
		  <input type="submit" name="submit" value="Cập nhật" class="btn" style="margin-left:267px"/>
		</div>
	  
	  </div>
	</form>
	  <script>
		// Get the user_info
		var user_info = document.getElementById("update");
		
		// Get the button that opens the user_info
		var btn = document.getElementById("myBtn");
		
		// Get the <span> element that closes the user_info
		var span = document.getElementsByClassName("close")[0];
		
		// When the user clicks the button, open the user_info 
		btn.onclick = function() {
		  user_info.style.display = "block";
		}
		
		// When the user clicks on <span> (x), close the user_info
		span.onclick = function() {
		  user_info.style.display = "none";
		}
	</script>
    <% include ./../elements/footer %>
</body>