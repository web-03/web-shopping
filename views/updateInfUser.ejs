<link href='//fonts.googleapis.com/css?family=Roboto+Condensed:400,700' rel='stylesheet' type='text/css'>
</head>
<body>
    <!-- Header -->
    <% include headeruser %>
    <form action="#" method="post">
    <div class="form-control w3layouts"> 
        <div>
            <input type="text" id="firstname" name="firstname" placeholder="Họ và tên" title="Đổi tên" required="">
        </div>

        <div class="form-control w3layouts">	
            <input type="email" id="email" name="email" placeholder="mail@example.com" title="Đổi Email" required="">
        </div>

        <div class="form-control agileinfo">	
            <input type="password" class="lock" name="password" placeholder="Mật khẩu" id="password1" title="Đổi mật khẩu"required="">
        </div>	
        <div class="form-control agileinfo">	
                <input type="password" class="lock" name="confirm-password" placeholder="Nhập lại mật khẩu" id="password2" title="Nhập lại mật khẩu"required="">
            </div>	
        <input type="submit" class="register" value="Đăng kí">
    </form>
</div>
			
<% include footer %>      
<script type="text/javascript">
    window.onload = function () {
        document.getElementById("password1").onchange = validatePassword;
        document.getElementById("password2").onchange = validatePassword;
    }
    function validatePassword(){
        var pass2=document.getElementById("password2").value;
        var pass1=document.getElementById("password1").value;
        if(pass1!=pass2)
            document.getElementById("password2").setCustomValidity("Mật khẩu không khớp");
        else
            document.getElementById("password2").setCustomValidity('');	 
            //empty string means no validation error
    }
</script>
</body>